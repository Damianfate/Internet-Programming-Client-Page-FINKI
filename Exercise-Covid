<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Title</title>
    <script src="https://cdn.plot.ly/plotly-latest.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js"></script>
</head>
<style>
    #flag{
        margin: 15px;
    }
</style>
<body>
<h1>COVID-19 Data Dashboard</h1>
<div id="container">
    <button onclick="VisualizeAllCountries()">View All Countries</button>
    <select id="select" onchange="VisualizeSinglecountry()">
        <option>Select a country</option>
    </select>
    <div id="zname">
        <img src="" id="flag" onclick="TransformFlag()">
    </div>

    <div id="chart">

    </div>
</div>
<script>
    let covidData=[];
    let isCircle=false;
    async function fetchData() {
        const response = await fetch('https://disease.sh/v3/covid-19/countries');
        covidData=await response.json();
        console.log(covidData);
        popolniDropdown();
        VisualizeAllCountries();
    }
    function popolniDropdown(){
        let select=document.getElementById("select")
        covidData.forEach(country=>{
            let option="<option>"+country.country+"</option>"
            // let option=document.createElement("option")
            // option.value=""
            select.innerHTML+=option;
        })
    }
    function VisualizeAllCountries(){
        let imeNaDrzava=covidData.map(country=>country.country);
        let Totalcases=covidData.map(country=>country.cases);
        let recovered=covidData.map(country=>country.recovered);
        let deaths=covidData.map(country=>country.deaths);
        let iminjaDrzavi={
            x:imeNaDrzava,
            y:Totalcases,
            name:"Total Cases",
            type:"bar"
        }
        let Recovered={
            x:imeNaDrzava,
            y:recovered,
            name:"recovered Cases",
            type:"bar"
        }
        let Deaths={
            x:imeNaDrzava,
            y:deaths,
            name:"Total Deaths",
            type:"bar"
        }
        let data=[iminjaDrzavi, Recovered, Deaths];
        let layout={
            barmode:'group',
            title:'Covid-19 cases for all countries'
        }
        Plotly.newPlot('chart', data,layout);
        hideFlag();
    }
    function VisualizeSinglecountry(){
        let CountryName=document.getElementById("select").value;
        let countryobj=covidData.find(country=>country.country===CountryName);
        let iminjaDrzavi={
            x:["Cases","Recovered","Deaths"],
            y:[countryobj.cases, countryobj.recovered, countryobj.deaths],
            type:"bar"
        }
        let data=[iminjaDrzavi];
        showFlag(countryobj.countryInfo.flag)
        Plotly.newPlot('chart', data);
    }
    function showFlag(img){
       document.getElementById("flag").setAttribute("src",img);
       anime({
           targets:"#flag",
           translateX:[-100,0],
           scale:[0,1],
           duration:700,
           easing:"easeOutQuad"
       })
    }
    function hideFlag(){
        document.getElementById("flag").setAttribute("src","")
    }
    function TransformFlag(){
        isCircle=!isCircle;
        anime({
            targets:"#flag",
            keyframes:[
                {scale:1.2, duration:500},
                {scale:1, duration: 500},
                {scale:1.2, duration:500}
            ],
            borderRadius: isCircle?["50%",0]: [0,"50%"],
            duration:500,
            easing:"easeInOutQuad"
        })
    }
    fetchData();
</script>
</body>
</html>
