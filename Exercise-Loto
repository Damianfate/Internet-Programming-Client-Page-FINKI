<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>kolokviumska4</title>
    <style>
        #forma, #lucky_numbers{
            display: inline-block;
            width: 250px;
            vertical-align: top;
        }
        #cards>div{
            display: inline-block;
            border: 1px solid black;
            width: 300px;
        }
        .krug{
            display: inline-block;
            border: 1px solid black;
            border-radius: 100%;
            padding: 5px;
            margin-right: 10px;
        }
        #win_combination{
            width: 500px;
        }
    </style>
</head>
<body>
<h1>Lottery game</h1>
<div id="forma">
    <h2>Forma</h2>
    <div>
        <div>
            Ime <input type="text" id="ime">
        </div>
        <div>
            Amount <input type="text" id="amount">
        </div>
        <div>
            Code <input type="text" id="code">
        </div>
        <div>
            Combo <input type="text" id="combo">
        </div>
        <div>
            Bonus: <select id="bonus">
            <option>Yes</option>
            <option>No</option>
        </select>
        </div>
        <button onclick="submit()">Add</button>
    </div>
</div>
<div id="lucky_numbers">
    <h2>Weekly combination</h2>
    <div id="win_combination">

    </div>
    <button onclick="get_comb()">Get weekly combination</button>
    <p>Total: <span id="total_win">0</span></p>
</div>
<div id="cards">

</div>
<script>
    var number_cards=0
    function submit(){
        var name=document.getElementById("ime").value
        var amount=document.getElementById("amount").value
        var code=document.getElementById("code").value
        var combination=document.getElementById("combo").value
        var bonus=document.getElementById("bonus").value
        if(name.length===0 || amount.length===0 || code.length===0 || combination.length===0){
            alert("Podatocite ne se vneseni!")
            return
        }
        var proverka=document.getElementById(code)
        if(proverka){
            alert("Postoecko ID!")
            return
        }
        for(var i=0; i<9; i++){
            //funkcijata indexOf() ako ne go najde dava -1, a ako go najde mu dava index
            //da ja koristime za prebaruvanje vo stringovi
            if(code.indexOf(i)!=-1){
                alert("Ne e validen kod!")
                return
            }
        }
        if(code.indexOf("!")!=-1 || code.indexOf("%")!=-1){
            alert("Ne e validen kod!")
            return
        }
        combo=combination.split(",")
        var combination_string=""
        for(var i=0; i<7; i++){
            combination_string+="<div class='krug' id='"+combo[i]+"'>"+combo[i]+"</div>"
        }
        var card='<div  title="'+bonus+'" class="karticka" id="'+code+'"><p>Name:'+name+'</p><p>Code:'+code+'</p><p>Combination:'+combination_string+'</p><p class="amount">Amount:'+amount+'</p><p>Total win:<span class="win"></span></p></div>'
        var cards=document.getElementById("cards")
        cards.innerHTML+=card
        number_cards++
    }
    function get_comb(){
        if(number_cards<5){
            return
        }
        var combination_string=""
        var boja=["lightpink","palevioletred","peachpuff","plum","hotpink","deeppink","orchid"]
        for(var i=0; i<7; i++){
            var broj=parseInt((Math.random()*31)+1)
            var exists=document.getElementById(broj)
            if(exists){
                i--
                continue
            }
            combination_string+="<p style='background-color:"+boja[i]+"' class='krug' id='"+broj+"'>"+broj+"</p>"
        }
        var win_comb=document.getElementById("win_combination")
        win_comb.innerHTML+=combination_string
        check_combination()
    }
    function check_combination(){
        var win_comb=document.getElementById("win_combination")
        win_comb=win_comb.getElementsByClassName("krug")
        var cards=document.getElementById("cards")
        cards=cards.getElementsByClassName("karticka")
        for(var i=0; i<5; i++){
            var dobitni=0
            var card_comb=cards[i].getElementsByClassName("krug")
            for(var j=0; j<7; j++){
                for(var k=0; k<7; k++)
                    if(win_comb[j].innerHTML==card_comb[k].innerHTML){
                        dobitni++
                    }
            }
            if(dobitni<=3)
                cards[i].style.background="yellow"
            else if(dobitni<=5)
                cards[i].style.background="blue"
            else
                cards[i].style.background="green"

            var bonus=cards[i].getAttribute("title")
            var card_total_win=dobitni*30
            if(bonus=="Yes"){
                card_total_win+=500
            }
            var uplata=cards[i].getElementsByClassName("amount")[0].innerHTML.split(":")[1]
            card_total_win+=parseInt(uplata)
            cards[i].getElementsByClassName("win")[0].innerHTML=card_total_win
            cards[i].innerHTML+="<button onclick='remove(this)'>Sold</button>"
            var total_every_card=document.getElementById("total_win")
            var total= parseInt(total_every_card.innerHTML)
            total+=card_total_win
            total_every_card.innerHTML=total
        }
    }
    function remove(obj){
        var element=obj.parentNode
        var card_total=element.getElementsByClassName("win")[0].innerHTML
        var total_every_card=document.getElementById("total_win")
        var total= parseInt(total_every_card.innerHTML)
        total-=card_total
        total_every_card.innerHTML=total
        element.remove()
    }
</script>
</body>
</html>
